<Window x:Class="Kar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kar" 
        xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Background="#383737"
        ResizeMode="CanResize"
        StateChanged="MainWindow_StateChanged"
        WindowStyle="None"
        Title="Main" Height="720" Width="1024">


    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="36"
            ResizeBorderThickness="5"
            GlassFrameThickness="0"
            CornerRadius="10"/>

    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:TabSelectionConverter x:Key="TabSelectionConverter"/>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TabPanel Grid.Row="0" 
                                      Grid.Column="0"
                                      Width="Auto"
                                      IsItemsHost="True" 
                                      Background="Transparent" 
                                      VerticalAlignment="Stretch"
                                      Panel.ZIndex="1"/>

                            <ContentPresenter 
                                Grid.Row="1"
                                
                                Grid.ColumnSpan="3"
                                ContentSource="SelectedContent" 
                                VerticalAlignment="Stretch" 
                                HorizontalAlignment="Stretch"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="TabBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="CornerRadius" Value="9,9,0,0"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource TabSelectionConverter}">
                            <Binding/>
                            <Binding Path="DataContext.SelectedTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#616161"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8d8c8c"/>
                </Trigger>
            </Style.Triggers>

        </Style>
    </Window.Resources>

    <Grid x:Name = "RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopRow" Height="34"/>
            <RowDefinition x:Name="PanelControl" Height="45"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
       
        <Grid Grid.Row="0" x:Name="TopBar" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>

            </Grid.ColumnDefinitions>
            <Grid Margin="2" shell:WindowChrome.IsHitTestVisibleInChrome="True" Grid.Column="0">

                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <local:TabPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.Resources>
                        <DataTemplate DataType="{x:Type local:TabViewModel}">
                            <Border Style="{StaticResource TabBorderStyle}" Height="28">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Title}" 
                                               VerticalAlignment="Center" 
                                               Margin="10,0,5,0" 
                                               Foreground="White"/>
                                    <Button Grid.Column="1" >
                                        <Path Data="M0.366106 0.366133C0.854253 -0.121894 1.64577 -0.121968 2.13387 0.366133L5.66941 3.90167L9.20425 0.366823C9.69239 -0.121315 10.4839 -0.121315 10.972 0.366823C11.4598 0.854986 11.4601 1.64655 10.972 2.13459L7.43717 5.66943L10.972 9.20428C11.4601 9.69238 11.46 10.4839 10.972 10.972C10.4839 11.4602 9.69239 11.4602 9.20425 10.972L5.66941 7.4372L2.13387 10.9727C1.64584 11.4608 0.854268 11.4606 0.366106 10.9727C-0.122032 10.4846 -0.122032 9.69311 0.366106 9.20497L3.90164 5.66943L0.366106 2.1339C-0.122032 1.64576 -0.122032 0.854271 0.366106 0.366133Z" Fill="#B3B1B1"/>

                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>

                        <DataTemplate DataType = "{x:Type local:AddButtonTab}">
                            <Border Width="20" Height="20" CornerRadius="12" Background="#666666" VerticalAlignment="Center" Margin="5,0">
                                <Button Background="Transparent" BorderThickness="0" Command="{Binding AddTabCommand, RelativeSource={RelativeSource AncestorType=Window} }">
                                    <Path Data="M10 4C10 3.44772 9.55228 3 9 3H6C5.44772 3 5 3.44772 5 4V7C5 7.55228 5.44772 8 6 8H9C9.55228 8 10 7.55228 10 7V4Z" Fill="#B3B1B1"/>
                                </Button>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.Resources>

                </ItemsControl>

               
            </Grid>
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Panel.ZIndex="10" 
                        Grid.Column="1">
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30" Click="MinimizeButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Rectangle Width="15" Height="2" RadiusY="1" RadiusX="1" Fill="#D9D9D9"/>
                </Button>
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30"  Click="MaximizeButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M15 14C15 14.5523 14.5523 15 14 15H1C0.447715 15 0 14.5523 0 14V1C0 0.447715 0.447715 0 1 0H14C14.5523 0 15 0.447715 15 1V14ZM3 2C2.44771 2 2 2.44772 2 3V12C2 12.5523 2.44772 13 3 13H12C12.5523 13 13 12.5523 13 12V3C13 2.44771 12.5523 2 12 2H3Z" Fill="#D9D9D9"/>

                </Button>
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30"  Click="CloseButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Data="M12.5577 0.41901C13.1164 -0.13967 14.0224 -0.13967 14.5811 0.41901C15.1398 0.977693 15.1398 1.88378 14.5811 2.44245L9.52253 7.50006L14.5811 12.5577C15.1397 13.1163 15.1397 14.0224 14.5811 14.5811C14.0225 15.1398 13.1164 15.1398 12.5577 14.5811L7.50006 9.5235L2.44245 14.5811C1.88378 15.1398 0.977693 15.1398 0.41901 14.5811C-0.13967 14.0224 -0.13967 13.1164 0.41901 12.5577L5.47663 7.50006L0.41901 2.44245C-0.13967 1.88377 -0.13967 0.97769 0.41901 0.41901C0.977645 -0.139515 1.88281 -0.139478 2.44147 0.41901L7.49909 5.47663L12.5577 0.41901Z" Fill="#D9D9D9"/>

                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Background="#616161" >
            <!-- Строка управления -->
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Top" Width="140" Margin="0">
                <Button Width="25" Height="25" Background="Transparent" BorderThickness="0" Command="{Binding SelectedTab.BackCommand}">
                    <Path Data="M16.0588 8.36377C16.6111 8.36377 17.0588 7.91605 17.0588 7.36377C17.0588 6.81148 16.6111 6.36377 16.0588 6.36377V7.36377V8.36377ZM0.292909 6.65666C-0.0976162 7.04719 -0.0976162 7.68035 0.292909 8.07088L6.65687 14.4348C7.04739 14.8254 7.68056 14.8254 8.07108 14.4348C8.46161 14.0443 8.46161 13.4111 8.07108 13.0206L2.41423 7.36377L8.07108 1.70692C8.46161 1.31639 8.46161 0.683226 8.07108 0.292702C7.68056 -0.0978227 7.04739 -0.0978227 6.65687 0.292702L0.292909 6.65666ZM16.0588 7.36377V6.36377L1.00002 6.36377V7.36377V8.36377L16.0588 8.36377V7.36377Z" Fill="#D9D9D9" />
                </Button>
                <Button Width="25" Height="25" Background="Transparent" BorderThickness="0" Command="{Binding SelectedTab.ForwardCommand}">
                    <Path Data="M1 8.36377C0.447715 8.36377 0 7.91605 0 7.36377C0 6.81148 0.447715 6.36377 1 6.36377L1 7.36377L1 8.36377ZM16.7659 6.65666C17.1565 7.04719 17.1565 7.68035 16.7659 8.07088L10.402 14.4348C10.0114 14.8254 9.37828 14.8254 8.98775 14.4348C8.59723 14.0443 8.59723 13.4111 8.98775 13.0206L14.6446 7.36377L8.98775 1.70692C8.59723 1.31639 8.59723 0.683226 8.98775 0.292702C9.37828 -0.0978227 10.0114 -0.0978227 10.402 0.292702L16.7659 6.65666ZM1 7.36377L1 6.36377L16.0588 6.36377V7.36377V8.36377L1 8.36377L1 7.36377Z" Fill="#D9D9D9"/>
                </Button>
                <Button Width="25" Height="25" Background="Transparent" BorderThickness="0" Command="{Binding SelectedTab.ReloadCommand}">
                    <Path Data="M15.4821 11.27C13.716 15.3623 8.96685 17.2479 4.87454 15.4819C0.782252 13.7157 -1.10346 8.96666 0.662732 4.87428C2.42897 0.78206 7.17807 -1.10366 11.2703 0.662473C12.9597 1.39165 14.2702 2.63146 15.1056 4.12056L15.3652 3.51892C15.5841 3.01204 16.1727 2.77844 16.6796 2.99703C17.1867 3.21586 17.4203 3.80438 17.2015 4.31143L15.9563 7.19676C15.7374 7.70374 15.1489 7.93747 14.6419 7.71865L11.7565 6.47339C11.2498 6.25442 11.016 5.6659 11.2346 5.159C11.4535 4.65217 12.0421 4.41861 12.549 4.63711L13.2789 4.9521C12.6478 3.89667 11.6925 3.02304 10.4778 2.49876C7.3997 1.17031 3.82756 2.58872 2.49902 5.66679C1.17052 8.745 2.58889 12.3171 5.66705 13.6456C8.74521 14.9739 12.3174 13.5557 13.6458 10.4775C13.8647 9.97058 14.4532 9.73683 14.9602 9.95565C15.4672 10.1745 15.7008 10.763 15.4821 11.27Z" Fill="#D9D9D9"/>

                </Button>
                <Button Width="25" Height="25" Background="Transparent" BorderThickness="0" Command="{Binding SelectedTab.HomeCommand}">
                    <Path Data="M13.0118 6.32745C13.1388 6.45314 13.0498 6.6696 12.8711 6.6696H12.3622C12.2517 6.6696 12.1622 6.75914 12.1622 6.8696V14.3466C12.1622 14.457 12.0726 14.5466 11.9622 14.5466H8.98621C8.87576 14.5466 8.78621 14.457 8.78621 14.3466V10.2456C8.78621 10.1351 8.69667 10.0456 8.58622 10.0456H4.48524C4.37478 10.0456 4.28524 10.1351 4.28524 10.2456V14.3466C4.28524 14.457 4.1957 14.5466 4.08524 14.5466H1.10926C0.998805 14.5466 0.909262 14.457 0.909262 14.3466V6.8696C0.909262 6.75914 0.819719 6.6696 0.709262 6.6696H0.200401C0.0217136 6.6696 -0.0672885 6.45312 0.0597248 6.32744L6.39553 0.0578379C6.47346 -0.0192831 6.59896 -0.0192788 6.67689 0.0578479L13.0118 6.32745Z" Fill="#D9D9D9"/>
                </Button>
            </StackPanel>
            <!-- Строка Поиска -->
            <Border CornerRadius="15" 
        Height="25" 
        Width="710" 
        Background="#8D8C8C" 
        VerticalAlignment="Top">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#Ebebeb" 
                            CornerRadius="15"
                            Padding="8,0">
                        <ComboBox x:Name="ChangedSearchSystem" 
                      ItemsSource="{Binding SearchSystems}" 
                      SelectedItem="{Binding SelectedSearchSystem}"
                      DisplayMemberPath="Name"
                      Background="Transparent" 
                      BorderThickness="0" 
                      VerticalAlignment="Center"
                      Height="22"
                      Width="100"/>
                    </Border>

                    <TextBox Grid.Column="1"
         Text="{Binding SelectedTab.Url, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
         KeyDown="UrlTextBox_KeyDown"
         Background="Transparent" 
         Foreground="White" 
         BorderThickness="0" 
         VerticalContentAlignment="Center"
         Padding="10,0"
         CaretBrush="White"/>
                </Grid>
            </Border>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Top" Width="140" Margin="5,0">
                <Button Width="25" Height="25" BorderThickness="0">
                    <Image/>
                </Button>
                <Button Width="25" Height="25" BorderThickness="0">
                    <Image/>
                </Button>
                <Button Width="25" Height="25"  BorderThickness="0">
                    <Image/>
                </Button>
            </StackPanel>

        </Grid>

        <Grid x:Name="BrowserHost" Grid.Row="2" Background="Transparent">
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.0" To="1.0"
                                             Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
    </Grid>
</Window>
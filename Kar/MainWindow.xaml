<Window x:Class="Kar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kar" 
        xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Background="#171717"
        ResizeMode="CanResize"
        StateChanged="MainWindow_StateChanged"
        WindowStyle="None"
        Title="Main" Height="720" Width="1024">


    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="36"
            ResizeBorderThickness="5"
            GlassFrameThickness="0"
            CornerRadius="10"/>

    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:TabSelectionConverter x:Key="TabSelectionConverter"/>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TabPanel Grid.Row="0" 
                                      Grid.Column="0"
                                      Width="Auto"
                                      IsItemsHost="True" 
                                      Background="Transparent" 
                                      VerticalAlignment="Stretch"
                                      Panel.ZIndex="1"/>

                            <ContentPresenter 
                                Grid.Row="1"
                                
                                Grid.ColumnSpan="3"
                                ContentSource="SelectedContent" 
                                VerticalAlignment="Stretch" 
                                HorizontalAlignment="Stretch"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="TabBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="CornerRadius" Value="9,9,0,0"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource TabSelectionConverter}">
                            <Binding/>
                            <Binding Path="DataContext.SelectedTab" RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#616161"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
            </Style.Triggers>

        </Style>
    </Window.Resources>

    <Grid x:Name = "RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TopRow" Height="36"/>
            <RowDefinition x:Name="PanelControl" Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" x:Name="TopBar" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ItemsControl x:Name="MainTab" ItemsSource="{Binding Tabs}" Grid.Column="0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource TabBorderStyle}" Width="150" Height="30">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                                        Command="{Binding DataContext.SelectedTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                        CommandParameter="{Binding}"/>
                            </Border.InputBindings>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Title}" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="10,0" 
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>

                                <Button Grid.Column="1" Margin="0,0,5,0" 
                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" BorderThickness="0" Width="15" Height="15" Background="Transparent">
                                    <Image Source="/CloseTabBtn.png" Width="12" Height="12"/>
                                </Button>
                            
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Grid.Column="1" 
                    Content="+"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Command="{Binding AddTabCommand}"
                    Width="30" Height="30" 
                    Margin="5,0"
                    BorderThickness="0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True" />

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Panel.ZIndex="10" 
                        Grid.Column="2">
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30" Click="MinimizeButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Image Source="/Assets/Icons/CollapseButton.png" Width="10" Height="10"/>
                </Button>
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30"  Click="MaximizeButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Image Source="/Assets/Icons/windowedButton.png" Width="10" Height="10"/>
                </Button>
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30"  Click="CloseButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Image Source="/Assets/Icons/CloseButton.png" Width="10" Height="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" >
            <!-- Строка управления -->
            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" VerticalAlignment="Center" Width="140" Margin="0">
                <Button Width="30" Height="30" Background="Transparent" BorderThickness="0" Command="{Binding SelectedTab.BackCommand}">
                    <Image Source="/Assets/Icons/ArrowB.png"/>
                </Button>
                <Button Width="30" Height="30" Background="Transparent" BorderThickness="0" Command="{Binding SelectedTab.ForwardCommand}">
                    <Image Source="/Assets/Icons/ArrowF.png"/>
                </Button>
                <Button Width="30" Height="30" Background="Transparent" BorderThickness="0" Command="{Binding SelectedTab.ReloadCommand}">
                    <Image Source="/Assets/Icons/update.png"/>
                </Button>
                <Button Width="30" Height="30" Background="Transparent" BorderThickness="0" Command="{Binding SelectedTab.HomeCommand}">
                    <Image Source="/Assets/Icons/Home.png"/>
                </Button>
            </StackPanel>
            <!-- Строка Поиска -->
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <ComboBox x:Name="ChangedSearchSystem" DisplayMemberPath="Name" SelectedValuePath="Name"  SelectionChanged="ChangedSearchSystem_SelectionChanged" Width="70"/>
                <TextBox Width="600"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center" Width="140" Margin="5,0">
                <Button Width="30" Height="30" BorderThickness="0">
                    <Image/>
                </Button>
                <Button Width="30" Height="30" BorderThickness="0">
                    <Image/>
                </Button>
                <Button Width="30" Height="30"  BorderThickness="0">
                    <Image/>
                </Button>
            </StackPanel>

        </Grid>

        <ContentControl Grid.Row="2" Content="{Binding SelectedTab}">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <local:TabContent Url="{Binding Url,Mode=TwoWay}"/>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</Window>
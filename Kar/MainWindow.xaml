                </Button>
                <Button Width="25" Height="25" BorderThickness="0" Background="Transparent" Cursor="Hand" Style="{StaticResource ChromeButtonStyle}" Command="{Binding DataContext.ExtentionsCommand, RelativeSource={RelativeSource AncestorType=Window}}" >
                    <Path Fill="#D9D9D9">
                        <Path.Data>
                            <GeometryGroup>
                                <PathGeometry Figures="M7.5 0C8.70949 0 9.71858 0.85886 9.9502 2H13C14.1046 2 15 2.89543 15 4V7.0498C16.1411 7.28142 17 8.29051 17 9.5C17 10.7094 16.141 11.7175 15 11.9492V15C15 16.1046 14.1046 17 13 17H2C0.895431 17 5.63733e-08 16.1046 0 15V12.9639C0.163332 12.9872 0.330206 13 0.5 13C2.433 13 4 11.433 4 9.5C4 7.567 2.433 6 0.5 6C0.330253 6 0.163289 6.0118 0 6.03516V4C0 2.89543 0.895431 2 2 2H5.0498C5.28142 0.85886 6.29051 0 7.5 0Z"/>
                            </GeometryGroup>
                        </Path.Data>
                    </Path>
                </Button>
                <ToggleButton x:Name="BtnDownload" Width="25" Height="25" ToolTip="Загрузки" BorderThickness="0" Background="Transparent"  Cursor="Hand">
                    <Path Data="M9.5 15.9961C9.77614 15.9961 10 16.22 10 16.4961C10 16.7722 9.77614 16.9961 9.5 16.9961H0.5C0.223858 16.9961 0 16.7722 0 16.4961C0 16.22 0.223858 15.9961 0.5 15.9961H9.5ZM5 0C5.27607 0 5.49989 0.223952 5.5 0.5V11.9824L7.82812 9.65332C8.02325 9.45831 8.33989 9.45854 8.53516 9.65332C8.73038 9.84855 8.73031 10.1651 8.53516 10.3604L5.35352 13.543C5.15829 13.738 4.84171 13.738 4.64648 13.543L1.46484 10.3604C1.26969 10.1651 1.26962 9.84855 1.46484 9.65332C1.66011 9.45854 1.97675 9.45831 2.17188 9.65332L4.5 11.9824V0.5C4.50011 0.223952 4.72393 0 5 0Z" Fill="#D9D9D9"/>
                </ToggleButton>

                <Popup IsOpen="{Binding IsChecked, ElementName = BtnDownload}" StaysOpen="False" PlacementTarget ="{Binding ElementName=BtnDownload}" Placement="Bottom">
                    <Border Background="#2B2B2B" BorderBrush="#2B2B2B" BorderThickness="1" CornerRadius="5" Width="300">
                        <StackPanel Margin="5">
                            <ItemsControl ItemsSource="{Binding RecentDownloads}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5,0">
                                            <TextBlock Text="{Binding FileName}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ProcessText}" Foreground="#9D9B9B" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            <ProgressBar Value ="{Binding Progress}" Maximum="100" Height="4" Margin="0,3,0,0" Background="#555" Foreground="#9D9B9B"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Separator Background="#3f3f3f" Margin="0,5"/>

                            <Grid>
                                <Grid.ColumnDefinitions>

<Window x:Class="Kar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kar"
        xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Background="#171717"
        ResizeMode="CanResize"
        WindowStyle="None"
        Title="Main" Height="720" Width="1024">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="36"
            ResizeBorderThickness="5"
            GlassFrameThickness="0"
            CornerRadius="10"/>

    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TabPanel Grid.Row="0" 
                                      Grid.Column="0"
                                      Width="Auto"
                                      IsItemsHost="True" 
                                      Background="Transparent" 
                                      VerticalAlignment="Stretch"
                                      Panel.ZIndex="1"/>

                            <ContentPresenter 
                                Grid.Row="1"
                                
                                Grid.ColumnSpan="3"
                                ContentSource="SelectedContent" 
                                VerticalAlignment="Stretch" 
                                HorizontalAlignment="Stretch"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" >
            <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
            
            <TabControl x:Name="MainTabs"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}"
                    Background="Transparent"
                    BorderThickness="0"
                    Grid.Row="1"
                    Grid.Column="0">
            

                    <TabControl.ItemTemplate>
                        <DataTemplate >
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <TextBlock Text="{Binding Title}" MaxWidth="100" TextTrimming="CharacterEllipsis"/>
                                <Button Content="X"
                                Margin="5,0,0,0"
                                Background="Transparent" 
                                BorderThickness="0" 
                                Click="CloseTabButton_Click"
                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <local:TabContent Url="{Binding Url, Mode=TwoWay}"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            
            <Button Grid.Column="1" 
                    Content="+" 
                    VerticalAlignment="Center"
                    Click="AddTabButton_Click" 
                    Width="30" Height="30" 
                    Margin="5,0"
                    BorderThickness="0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Panel.ZIndex="10" 
                        Grid.Column="2">
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30" Click="MinimizeButton_Click">
                    <Image Source="/Assets/Icons/CollapseButton.png" Width="10" Height="10"/>
                </Button>
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30"  Click="MaximizeButton_Click">
                    <Image Source="/Assets/Icons/windowedButton.png" Width="10" Height="10"/>
                </Button>
                <Button Style="{StaticResource ChromeButtonStyle}" Width="30" Height="30"  Click="CloseButton_Click">
                    <Image Source="/Assets/Icons/CloseButton.png" Width="10" Height="10"/>
                </Button>
            </StackPanel>
        </Grid>

        <ContentControl Grid.Row="1" Content="{Binding SelectedTab}">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <local:TabContent Url="{Binding Url,Mode=TwoWay}"/>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>
    </Grid>
</Window>
